{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantpulse.local/schema/research-intent.json",
  "title": "Quant Pulse Research Intent",
  "description": "Structured research hypothesis or risk filter emitted to QuantLab based on validated signal candidates.",
  "type": "object",
  "required": [
    "candidate_id",
    "hypothesis_type",
    "bias_direction",
    "affected_universe",
    "time_horizon",
    "validation_goal",
    "invalidation_signal",
    "route",
    "score",
    "confidence",
    "timestamp"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "description": "ID of the source candidate in automation/candidates/"
    },
    "hypothesis_type": {
      "type": "string",
      "enum": [
        "trend",
        "mean_reversion",
        "event_driven",
        "risk_filter",
        "regime-risk",
        "rotation",
        "product_priority"
      ]
    },
    "bias_direction": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "neutral",
        "regime-risk"
      ]
    },
    "affected_universe": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of assets, sectors, or venues affected (e.g. ['BTC', 'ETH', 'EXCHANGES'])"
    },
    "time_horizon": {
      "type": "string",
      "description": "Expected duration of the hypothesis (e.g. 'hours', 'days_to_weeks')"
    },
    "validation_goal": {
      "type": "string",
      "description": "What QuantLab should prove or disprove"
    },
    "invalidation_signal": {
      "type": "string",
      "description": "Market signal that would invalidate this intent"
    },
    "route": {
      "type": "string",
      "enum": [
        "research_hypothesis",
        "risk_filter",
        "product_priority"
      ],
      "description": "Downstream processing path in QuantLab"
    },
    "risk_filter_hint": {
      "type": "string",
      "description": "Optional hints for risk engine (e.g. 'venue gating')"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
