{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whiteks1.github.io/quant-pulse/schemas/research-intent.schema.json",
  "title": "Quant Pulse Research Intent",
  "description": "Structured research hypothesis or risk filter emitted to QuantLab based on validated signal candidates.",
  "type": "object",
  "required": [
    "intent_id",
    "hypothesis_type",
    "bias",
    "affected_universe",
    "horizon",
    "validation_goal",
    "invalidation_condition",
    "route",
    "created_at"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "description": "Unique intent identifier (ri:<id>:<route>)"
    },
    "candidate_id": {
      "type": "string",
      "description": "Original candidate identifier for internal traceability"
    },
    "edition_id": {
      "type": "string",
      "description": "Edition ID in format YYYY-MM-DD_vN"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "hypothesis_type": {
      "type": "string",
      "enum": [
        "trend",
        "mean_reversion",
        "event_driven",
        "risk_filter",
        "regime-risk",
        "rotation",
        "product_priority"
      ]
    },
    "bias": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "neutral",
        "regime-risk"
      ]
    },
    "affected_universe": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "horizon": {
      "type": "string",
      "description": "Expected duration (e.g. 'days to weeks')"
    },
    "signal_summary": {
      "type": "string",
      "description": "Human readable summary of the signal's core hypothesis"
    },
    "validation_goal": {
      "type": "string"
    },
    "invalidation_condition": {
      "type": "string"
    },
    "route": {
      "type": "string",
      "enum": [
        "research_hypothesis",
        "risk_filter",
        "product_priority"
      ]
    },
    "risk_filter_hint": {
      "type": "string"
    },
    "product_priority_hint": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Compatibility field (optional)"
    },
    "source_ref": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
