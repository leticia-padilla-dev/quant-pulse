{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantpulse.local/schema/candidate.json",
  "title": "Quant Pulse Candidate Signal",
  "description": "Governance schema for signal candidates in evaluation pipeline. Separates operational state from canonical feed (`pulse.source.json`).",
  "type": "object",
  "required": [
    "id",
    "state",
    "source",
    "score",
    "confidence",
    "decision",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique candidate identifier (UUID v4 or slug + timestamp)",
      "minLength": 8,
      "maxLength": 255
    },
    "state": {
      "type": "string",
      "enum": [
        "no_candidate",
        "candidate",
        "ready_for_review",
        "published",
        "archived"
      ],
      "description": "Lifecycle state. Gate thresholds enforce transitions defined in automation/gates/approval_gates.yaml"
    },
    "source": {
      "type": "string",
      "description": "Source identifier (from config/approved-sources.yaml)",
      "minLength": 2,
      "maxLength": 100
    },
    "title": {
      "type": "string",
      "description": "Signal title (human readable)",
      "minLength": 5,
      "maxLength": 200
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the signal (150-300 chars)"
    },
    "category": {
      "type": "string",
      "description": "Category per docs/category-taxonomy.es.md",
      "enum": [
        "Macro_Liquidity",
        "Btc_Whale_Activity",
        "Eth_Regulatory",
        "Web3_Structure",
        "Execution_Risk",
        "Broker_Rail_Risk",
        "Technology_Infrastructure",
        "Other"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Numerical confidence score (0-100). P1≥70, P2≥40, P3<40"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "System confidence in score (0-1). Gates: min=0.50, ready_for_review≥0.75"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when this candidate was created"
    },
    "decision": {
      "type": "object",
      "required": ["gate_applied", "timestamp", "reason"],
      "properties": {
        "gate_applied": {
          "type": "string",
          "enum": [
            "no_candidate",
            "candidate",
            "ready_for_review"
          ],
          "description": "Which gate allowed this state"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of decision)"
        },
        "reason": {
          "type": "string",
          "description": "Human-readable justification for gate result"
        },
        "evaluator": {
          "type": "string",
          "description": "System or user name that made the decision"
        }
      },
      "additionalProperties": false
    },
    "state_transitions": {
      "type": "array",
      "description": "Audit trail of all state changes",
      "items": {
        "type": "object",
        "required": ["from", "to", "timestamp", "reason"],
        "properties": {
          "from": {
            "type": "string",
            "enum": [
              "no_candidate",
              "candidate",
              "ready_for_review",
              "published",
              "archived"
            ]
          },
          "to": {
            "type": "string",
            "enum": [
              "no_candidate",
              "candidate",
              "ready_for_review",
              "published",
              "archived"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata for enrichment (links, parent signals, etc)",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
